{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://toothless-bite.local/schema/governance.schema.json",
  "title": "治理落差評估矩陣",
  "description": "5 資料來源 × 14 治理維度 = 70 格評估。框架分為 CARE (4)、OCAP (4)、TK Labels (3)、在地化 (3)。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "date_checked", "methodology_ref", "sources"],
  "properties": {
    "schema_version": { "type": "string" },
    "date_checked": { "type": "string", "format": "date" },
    "methodology_ref": {
      "type": "string",
      "description": "評分方法論文件路徑（docs/governance-dimensions.md）"
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cip", "data-gov-tw", "ticd", "ailt", "tcmb", "openmuseum"],
      "properties": {
        "cip": { "$ref": "#/definitions/sourceEvaluation" },
        "data-gov-tw": { "$ref": "#/definitions/sourceEvaluation" },
        "ticd": { "$ref": "#/definitions/sourceEvaluation" },
        "ailt": { "$ref": "#/definitions/sourceEvaluation" },
        "tcmb": { "$ref": "#/definitions/sourceEvaluation" },
        "openmuseum": { "$ref": "#/definitions/sourceEvaluation" }
      }
    }
  },
  "definitions": {
    "sourceEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checked_documents", "scores"],
      "properties": {
        "checked_documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[\\w./-]+(:L\\d+-L\\d+)?$",
            "description": "實際檢查過的文件（檔案路徑或 file:L{n}-L{n}）"
          },
          "description": "本次評分基於哪些實際讀過的文件——確保 none 評分不是「未檢查」"
        },
        "scores": {
          "type": "object",
          "additionalProperties": false,
          "required": ["CARE", "OCAP", "TK_Labels", "localized"],
          "properties": {
            "CARE": { "$ref": "#/definitions/careScores" },
            "OCAP": { "$ref": "#/definitions/ocapScores" },
            "TK_Labels": { "$ref": "#/definitions/tkScores" },
            "localized": { "$ref": "#/definitions/localizedScores" }
          }
        }
      }
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score"],
      "properties": {
        "score": {
          "type": "string",
          "enum": ["none", "partial", "implemented"]
        },
        "rationale": {
          "type": "string",
          "description": "評分理由；partial/implemented 必填"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[\\w./-]+:L\\d+-L\\d+$",
            "description": "證據引用，格式 file:L{n}-L{n}"
          },
          "description": "partial/implemented 必填"
        }
      }
    },
    "careScores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collective_benefit", "authority_to_control", "responsibility", "ethics"],
      "properties": {
        "collective_benefit": { "$ref": "#/definitions/cell" },
        "authority_to_control": { "$ref": "#/definitions/cell" },
        "responsibility": { "$ref": "#/definitions/cell" },
        "ethics": { "$ref": "#/definitions/cell" }
      }
    },
    "ocapScores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ownership", "control", "access", "possession"],
      "properties": {
        "ownership": { "$ref": "#/definitions/cell" },
        "control": { "$ref": "#/definitions/cell" },
        "access": { "$ref": "#/definitions/cell" },
        "possession": { "$ref": "#/definitions/cell" }
      }
    },
    "tkScores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provenance", "protocol", "permission"],
      "properties": {
        "provenance": { "$ref": "#/definitions/cell" },
        "protocol": { "$ref": "#/definitions/cell" },
        "permission": { "$ref": "#/definitions/cell" }
      }
    },
    "localizedScores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consultation_consent", "traditional_knowledge_protection", "rights_respect_clause"],
      "properties": {
        "consultation_consent": {
          "$ref": "#/definitions/cell",
          "description": "土地／自然資源諮商同意（原基法 21 條延伸）"
        },
        "traditional_knowledge_protection": {
          "$ref": "#/definitions/cell",
          "description": "傳統智慧創作保護"
        },
        "rights_respect_clause": {
          "$ref": "#/definitions/cell",
          "description": "資料使用的原住民族權益尊重條款"
        }
      }
    }
  }
}
